# Skopiuj do .env.local i uzupełnij. NIE commituj .env.local.
# Wartości znajdziesz w Supabase → Project Settings → API oraz w panelach P24/Fakturownia/Resend.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # tylko serwer (webhooki, admin, import) — nigdy w kliencie

# --- Przelewy24 ---
P24_MERCHANT_ID=
P24_POS_ID=
P24_API_KEY=
P24_CRC=

# --- Fakturownia ---
FAKTUROWNIA_API_TOKEN=
FAKTUROWNIA_DOMAIN=

# --- Resend (e-mail transakcyjny) ---
RESEND_API_KEY=
